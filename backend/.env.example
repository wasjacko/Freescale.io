# ===================================================================
# Freescale — Configuration Gmail OAuth
# ===================================================================
# 1. Va sur https://console.cloud.google.com
# 2. Crée un projet (ou utilise un existant)
# 3. Active l'API Gmail (APIs & Services > Enable APIs > Gmail API)
# 4. Va dans APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
# 5. Type: "Web application"
# 6. Authorized redirect URIs: http://localhost:3001/auth/google/callback
# 7. Copie le Client ID et Client Secret ci-dessous
# 8. Renomme ce fichier en .env
# ===================================================================

GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Ne pas changer sauf si tu modifies le port du backend
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
FRONTEND_URL=http://localhost:8002

# Port du backend
PORT=3001
